local function C_178()
    if getgenv()._robloxLoaded then return end
    getgenv()._robloxLoaded = true
    
    local script = VR7["178"];
    local logserv = game:GetService("LogService")
    local header = script.Parent.Console.ScrollingFrame.Header
    
    for i,v in pairs(header:GetChildren()) do
        if v:IsA("TextLabel") then v:Destroy() end
    end
    
    local lastMessage = ""
    local lastTime = 0
    
    local function addToRoblox(text, color)
        local now = tick()
        if text == lastMessage and (now - lastTime) < 0.5 then
            return
        end
        lastMessage = text
        lastTime = now
        
        local msg = Instance.new("TextLabel")
        msg.Parent = header
        msg.Size = UDim2.new(0.95, 0, 0, 0)
        msg.Text = tostring(text)
        msg.TextColor3 = color or Color3.fromRGB(220, 220, 220)
        msg.BackgroundTransparency = 1
        msg.TextSize = 12
        msg.TextXAlignment = Enum.TextXAlignment.Left
        msg.Font = Enum.Font.Gotham
        msg.TextWrapped = true
        msg.AutomaticSize = Enum.AutomaticSize.Y
        
        task.wait()
        script.Parent.Console.ScrollingFrame.CanvasPosition = Vector2.new(0, 999999)
    end
    
    local oldPrint = print
    print = function(...)
        local args = {...}
        local text = table.concat(args, " ")
        addToRoblox(text, Color3.fromRGB(220, 220, 220))
        oldPrint(...)
    end
    
    logserv.MessageOut:Connect(function(output, outputType)
        local color = Color3.fromRGB(220, 220, 220)
        if outputType == Enum.MessageType.MessageError then
            color = Color3.fromRGB(255, 80, 80)
        elseif outputType == Enum.MessageType.MessageWarning then
            color = Color3.fromRGB(255, 200, 80)
        elseif outputType == Enum.MessageType.MessageInfo then
            color = Color3.fromRGB(80, 150, 255)
        end
        addToRoblox(output, color)
    end)
    
    script.Parent.Buttons.Clear.MouseButton1Click:Connect(function()
        for i,v in pairs(header:GetChildren()) do
            if v:IsA("TextLabel") then v:Destroy() end
        end
    end)
