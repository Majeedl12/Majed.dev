-- StarterGui.VR7.Executor.Executor.Overlay.Buttons.ButtonHandlers
local function C_b2()
	local btns = script.Parent
	local overlay = btns.Parent
	local codeFolder = overlay:FindFirstChild("Code")

	local function getActiveTextBox()
		if not codeFolder then return nil end
		for _, v in pairs(codeFolder:GetChildren()) do
			if v:IsA("TextBox") and v.Visible == true then
				return v
			end
		end
		return nil
	end

	local function clearAllBoxes()
		if not codeFolder then return end
		for _, v in pairs(codeFolder:GetChildren()) do
			if v:IsA("TextBox") then
				v.Text = ""
			end
		end
	end

	local function executeSafe(codeText)
		if not codeText or not codeText:match("%S") then return end
		task.defer(function()
			local fn, err = loadstring(codeText)
			if fn then
				pcall(fn)
			elseif typeof(executescript) == "function" then
				pcall(executescript, codeText)
			end
		end)
	end

	btns.Execute.MouseButton1Click:Connect(function()
		local active = getActiveTextBox()
		if active then
			executeSafe(active.Text)
		end
	end)

	btns.Clear.MouseButton1Click:Connect(clearAllBoxes)

	btns.ExecuteClipboard.MouseButton1Click:Connect(function()
		if typeof(getclipboard) ~= "function" then
			if typeof(executeclipboard) == "function" then
				task.defer(pcall, executeclipboard)
			end
			return
		end

		local clipText = getclipboard()
		if not clipText or not clipText:match("%S") then return end

		local active = getActiveTextBox()
		if active then
			active.Text = clipText
		end
		executeSafe(clipText)
	end)

	if codeFolder then
		for _, box in pairs(codeFolder:GetChildren()) do
			if box:IsA("TextBox") then
				box.DragEnter:Connect(function(dragData)
					if dragData and #dragData:GetFiles() > 0 then
						dragData:SetDropAllowed(true)
					end
				end)
				box.Drop:Connect(function(dragData)
					local files = dragData:GetFiles()
					if files and #files > 0 then
						local content = readfile(files[1])
						if content then
							box.Text = content
						end
					end
				end)
			end
		end
	end
end

